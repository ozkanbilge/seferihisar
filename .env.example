# Kopyala: cp .env.example .env.local — değerleri kendine göre doldur

# Admin API koruması (sunucu tarafı; x-admin-key başlığıyla eşleşmeli)
ADMIN_KEY=degistir-beni

# Admin panel istemci tarafı (panelden API'ye gönderilen anahtar — ADMIN_KEY ile aynı olmalı)
NEXT_PUBLIC_ADMIN_KEY=degistir-beni

# Admin panel giriş bilgileri
NEXT_PUBLIC_ADMIN_EMAIL=admin@ornek.com
NEXT_PUBLIC_ADMIN_PASSWORD=degistir-beni

# Veritabanı (Prisma/NextAuth için)
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
